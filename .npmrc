# Supply-chain guardrail: refuse to install any dependency version published
# less than 14 days ago. Malicious package releases are typically detected
# and unpublished within a few days; this window gives near-full coverage
# without dragging normal patch adoption too far.
#
# Requires npm >= 10.9. Override for urgent CVE patches by either bumping
# the exclude list below or running `npm install --minimum-release-age=0`
# for that one install.
minimum-release-age=20160

# Allow our own scoped packages through instantly — @infinibay/* workspace
# publishes need to be consumable without waiting out the 14-day window.
minimum-release-age-exclude=@infinibay/*
